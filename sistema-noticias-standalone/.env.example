# Clave de API de Google Gemini (Gratuita en https://aistudio.google.com/)
GEMINI_API_KEY=tu_clave_gemini_aqui

# URL de tu sitio web desplegado (ej. https://tu-sitio.vercel.app)
SITE_URL=https://tu-sitio-web.com

# Nombre de tu marca o medio digital
SITE_NAME=MiDiarioDigital

# Consulta de búsqueda para Google News RSS (ej. Argentina, Mexico, España, Tecnologia, etc.)
SEARCH_QUERY=Argentina

# Cookie auth_token extraída de x.com para publicación automática gratuita en X
TWITTER_AUTH_TOKEN=tu_cookie_auth_token_aqui

# Modo Headless para Playwright (true en la nube, false para desarrollo local)
HEADLESS=true
